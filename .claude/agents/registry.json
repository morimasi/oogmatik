        {
          "step": 3,
          "name": "Unanimous Approval",
          "action": "TÜM lider ajanlar onay vermeli (veto hakkı var)"
        },
        {
          "step": 4,
          "name": "Implementation",
          "action": "Sadece onay sonrası uygulama"
        },
        {
          "step": 5,
          "name": "Verification",
          "action": "Lider ajanlar çıktıyı doğrular"
        }
      ]
    }

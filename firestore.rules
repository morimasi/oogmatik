rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && userDoc().role in ['admin', 'superadmin'];
    }

    function isTeacher() {
      return isAuthenticated() && userDoc().role in ['teacher', 'admin', 'superadmin'];
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Kullanıcı Profilleri
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    // Öğrenci Verileri (KVKK Hassasiyeti)
    match /students/{studentId} {
      allow read: if isAdmin() || 
        (isTeacher() && (request.auth.uid in resource.data.assignedTeachers || resource.data.teacherId == request.auth.uid));
      allow create: if isTeacher() || isAdmin();
      allow update: if isAdmin() || 
        (isTeacher() && (request.auth.uid in resource.data.assignedTeachers || resource.data.teacherId == request.auth.uid));
      allow delete: if isAdmin();

      match /{allSubcollections=**} {
        allow read: if isAdmin() || 
          (isTeacher() && (request.auth.uid in resource.data.assignedTeachers || resource.data.teacherId == request.auth.uid));
        allow write: if isAdmin() || isTeacher();
      }
    }

    // Çalışma Kağıtları ve Şablonlar
    match /worksheets/{worksheetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isTeacher();
    }

    match /saved_worksheets/{worksheetId} {
      allow read: if isAuthenticated() && 
        (resource.data.userId == request.auth.uid || 
         request.auth.uid in resource.data.sharedWith ||
         resource.data.studentId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }

    match /saved_assessments/{assessmentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /saved_curriculums/{curriculumId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /saved_screenings/{screeningId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Admin config koleksiyonları
    match /config_activities/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /config_prompts/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /config_snippets/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /config_static_content/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /activity_drafts/{docId} {
      allow read, write: if isAdmin() || isTeacher();
    }

    match /approval_queue/{docId} {
      allow read, write: if isAdmin() || isTeacher();
    }

    match /feedback_signals/{docId} {
      allow read: if isAdmin() || isTeacher();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Workbook v2
    match /workbooks/{workbookId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /workbook_pages/{pageId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /workbook_versions/{versionId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Profil paylaşımı
    match /shared_profile_content/{shareId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin()
        || (isAuthenticated() && resource.data.ownerId == request.auth.uid)
        || (isAuthenticated() && resource.data.recipientId == request.auth.uid);
    }

    // Geri Bildirimler
    match /feedbacks/{feedbackId} {
      allow read: if isAdmin() || isTeacher();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Global Ayarlar
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Fascicles
    match /fascicles/{fascicleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Atamalar (Assignments)
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update: if isTeacher() || isAdmin();
      allow delete: if isAdmin();
    }

    // Aktivite Logları
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Mesajlaşma
    match /conversations/{conversationId} {
      allow read, write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read, write: if isAuthenticated();
    }

    // E-posta
    match /sent_emails/{emailId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Fascicle Etkileşim Logları
    match /fascicleInteractionLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}

# OOGMATIK Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local to git!

# ============================================================
# AI API KEYS (Server-side only - NO VITE_ prefix!)
# ============================================================
GEMINI_API_KEY=your-gemini-api-key-here
GOOGLE_API_KEY=your-google-api-key-here
API_KEY=fallback-api-key-here

# ============================================================
# SECURITY & PRIVACY (Server-side only)
# ============================================================
# TC Kimlik No hash salt (minimum 32 characters)
TC_HASH_SALT=change-this-to-random-32-char-string-in-production

# Student ID anonymization salt (minimum 32 characters)
STUDENT_ID_SALT=change-this-to-another-random-32-char-string

# ============================================================
# VERCEL (Auto-populated in Vercel deployments)
# ============================================================
VERCEL=1
VERCEL_URL=your-preview-url.vercel.app

# ============================================================
# NODE ENVIRONMENT
# ============================================================
NODE_ENV=development

# ============================================================
# CLIENT-SIDE VARIABLES (Optional - Only for NON-SENSITIVE data)
# ============================================================
# These WILL be exposed to the browser
VITE_APP_VERSION=1.0.3

# Ā NEVER PUT API KEYS WITH VITE_ PREFIX!
# L VITE_GEMINI_API_KEY=xxx  <-- WRONG! Browser will see this!
#  GEMINI_API_KEY=xxx       <-- CORRECT! Server-side only

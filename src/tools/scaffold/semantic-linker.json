{
  "identity": {
    "key": "SEMANTIC_LINKER",
    "enumValue": "semantic-linker",
    "title": "İlişkiyi Bul (Anlamsal Bağ)",
    "description": "Verilen kelime ile görseller arasında anlamsal ilişki kurma veya aykırı olanı bulma etkinliği.",
    "icon": "fa-link",
    "categoryId": "reading-verbal"
  },
  "dataModel": {
    "interfaceName": "SemanticLinkerItem",
    "itemsName": "SemanticLinkerData",
    "fields": [
      { "name": "instruction", "type": "string", "required": true }
    ],
    "itemFields": [
      { "name": "targetWord", "type": "string", "required": true },
      { "name": "isNegated", "type": "boolean", "required": true },
      { "name": "options", "type": "array", "required": true },
      { "name": "correctAnswerId", "type": "string", "required": true }
    ]
  },
  "logic": {
    "aiPrompt": {
      "role": "Kıdemli Özel Eğitim Materyal Tasarımcısı",
      "task": "Verilen yaş grubuna uygun, anlamsal olarak birbiriyle ilişkili veya zıt olan kelime ve nesne setleri oluştur.",
      "rules": [
        "Soru tiplerini %50 olumlu ('hangisiyle ilişkilidir?'), %50 olumsuz ('hangisiyle ilişkili değildir?') olarak dağıt.",
        "Disleksi dostu, somut ve görselleştirilebilir kelimeler seç.",
        "Seçenekler net ve tartışmasız olsun."
      ],
      "schema": {
        "type": "OBJECT",
        "properties": {
          "items": {
            "type": "ARRAY",
            "items": {
              "type": "OBJECT",
              "properties": {
                "targetWord": { "type": "STRING" },
                "isNegated": { "type": "BOOLEAN" },
                "options": {
                  "type": "ARRAY",
                  "items": {
                    "type": "OBJECT",
                    "properties": {
                      "id": { "type": "STRING" },
                      "label": { "type": "STRING" },
                      "isCorrect": { "type": "BOOLEAN" }
                    }
                  }
                },
                "correctAnswerId": { "type": "STRING" }
              }
            }
          }
        }
      }
    }
  }
}
